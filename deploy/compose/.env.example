# misskey-s3-compactor configuration for Docker Compose.
# Copy this file to .env and fill in the real values.
#   cp .env.example .env

# ── S3 connection (mirrors deploy/configmap.yaml + deploy/secret.yaml) ───────
S3_BUCKET=misskey-media
S3_PREFIX=misskey/
S3_REGION=us-east-1
# Leave empty for AWS S3. Set for MinIO/R2/etc.: https://s3.example.com
S3_ENDPOINT=
# Set to true for MinIO/SeaweedFS/Cloudflare R2 etc.
S3_USE_PATH_STYLE=true

# ── Credentials (Secret) ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_SECRET_KEY
# Optional — only when using STS temporary credentials.
AWS_SESSION_TOKEN=

# ── Image compression ─────────────────────────────────────────────────────────
JPEG_QUALITY=80
PNG_STRIP_METADATA=true
WEBP_QUALITY=80
GIF_FLAGS=--optimize=3

# ── Video compression (HEVC via ffmpeg) ───────────────────────────────────────
VIDEO_CODEC=libx265
VIDEO_PRESET=medium
VIDEO_CRF=26
VIDEO_PIXFMT=yuv420p

# ── Behavior ──────────────────────────────────────────────────────────────────
DRY_RUN=false
SKIP_MARKED=true
MARKER_KEY=x-amz-meta-compactor
MIN_SAVING_RATIO=0.05
MAX_OBJECT_BYTES=2147483648
LOG_LEVEL=info